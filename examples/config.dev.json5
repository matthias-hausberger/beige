{
  // Beige Development Configuration
  //
  // Mirrors the beige-deploy production config but uses LOCAL plugin paths
  // from the sibling beige-toolkit repo (../beige-toolkit/).
  //
  // Usage:
  //   pnpm run dev                           # copies this config + starts gateway with kfl secrets
  //   pnpm run dev:tui                       # starts TUI against the running gateway
  //
  // Secrets are injected via Keyflare (kfl) from the beige-deploy project.

  $schema: "https://raw.githubusercontent.com/matthias-hausberger/beige/main/config.schema.json",

  llm: {
    providers: {
      zai: {
        apiKey: "${ZAI_API_KEY}",
      },
      anthropic: {
        // OAuth credentials managed via /login — stored in ~/.beige/auth.json
      },
    },
  },

  // ── Plugins (local paths) ──────────────────────────────────────────────────
  // All paths are relative to this config file's location (.beige/config.json5).
  // ../../beige-toolkit/ resolves to the sibling beige-toolkit repo.

  plugins: {
    git: {
      path: "../../beige-toolkit/plugins/git",
      config: {
        "identity.name": "Agent Beige",
        "identity.email": "${GITHUB_EMAIL}",
      },
    },
    github: {
      path: "../../beige-toolkit/plugins/github",
      config: {
        token: "${GITHUB_TOKEN}",
      },
    },
    chrome: {
      path: "../../beige-toolkit/plugins/chrome",
      config: {
        headless: false,
      },
    },
    sessions: {
      path: "../../beige-toolkit/plugins/sessions",
    },
    spawn: {
      path: "../../beige-toolkit/plugins/spawn",
      config: {
        targets: {
          SELF: {},
        },
        maxDepth: 2,
      },
    },
    wrangler: {
      path: "../../beige-toolkit/plugins/wrangler",
      config: {
        accountId: "${CLOUDFLARE_ACCOUNT_ID}",
        apiToken: "${CLOUDFLARE_API_TOKEN}",
      },
    },
    slack: {
      path: "../../beige-toolkit/plugins/slack",
    },
    confluence: {
      path: "../../beige-toolkit/plugins/confluence",
    },
    schedule: {
      path: "../../beige-toolkit/plugins/schedule",
      config: {
        tickInterval: 15,
      },
    },
    telegram: {
      path: "../../beige-toolkit/plugins/telegram",
      config: {
        token: "${TELEGRAM_BOT_TOKEN}",
        allowedUsers: ["${TELEGRAM_USER_ID}"],
        agentMapping: {
          default: "beige",
        },
        defaults: {
          verbose: false,
          streaming: true,
        },
      },
    },
  },

  agents: {
    beige: {
      model: {
        provider: "zai",
        model: "glm-4.7",
        thinkingLevel: "off",
      },
      fallbackModels: [
        {
          provider: "anthropic",
          model: "claude-sonnet-4.6",
          thinkingLevel: "off",
        },
      ],
      tools: ["chrome", "sessions", "spawn", "git", "github", "wrangler", "telegram", "schedule"],
      sandbox: {
        image: "beige-sandbox:latest",
      },
    },
  },
}
